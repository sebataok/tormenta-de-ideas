# ------------------------------------------------------------------
# Tormenta de Ideas — plantilla de variables de entorno
# Copiá este archivo como .env (mismo directorio) y completá los valores.
# NUNCA subas .env al repo (ya está en .gitignore).
# ------------------------------------------------------------------

# --- Supabase (Project Settings → API) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...ANON_PUBLIC
# Opcional pero recomendado — sólo en backend, JAMÁS en la PWA
SUPABASE_SERVICE_KEY=eyJhbGciOi...SERVICE_ROLE

# --- Gmail (2FA + App Password de 16 caracteres) ---
GMAIL_USER=sagonzar@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
NOTIFICATION_EMAIL=sagonzar@gmail.com

# --- PIN opcional (SHA-256 hex del PIN de 4 dígitos) ---
# En el MVP el PIN vive en el localStorage del iPhone. Este valor es
# opcional: sirve como source of truth por si querés propagarlo desde
# Supabase en el futuro. Dejá vacío para no usarlo.
PIN_HASH=

# --- Bucket y voz TTS ---
PODCAST_BUCKET=podcasts
TTS_VOICE=es-CL-CatalinaNeural
TTS_RATE=+5%
TTS_PITCH=+0Hz

# --- Claude CLI ---
# 'claude' usa el CLI de tu plan; 'local' usa un stub (SCRIPT_STUB).
CLAUDE_CMD=claude
# SCRIPT_STUB=./tests/stub_script.txt

# --- Comportamiento del loop ---
MAX_PER_RUN=3
